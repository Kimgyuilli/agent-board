{
  "name": "@agent-board/mcp-server",
  "version": "0.0.1",
  "description": "Agent Board MCP 도구 서버",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=node --packages=external && esbuild src/board-server.ts --bundle --outfile=dist/board-server.js --format=cjs --platform=node --external:better-sqlite3",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@agent-board/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "esbuild": "^0.24.0"
  }
}
