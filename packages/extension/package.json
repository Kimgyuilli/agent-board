{
  "name": "agent-board",
  "version": "0.0.1",
  "displayName": "Agent Board",
  "description": "AI 에이전트의 개발 태스크를 관리하고 활동을 실시간 모니터링하는 VS Code 확장",
  "publisher": "agent-board",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimgyuilli/agent-board"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agent-board.showBoard",
        "title": "Agent Board: Show Board"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-board",
          "title": "Agent Board",
          "icon": "resources/board-icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Agent Board",
      "properties": {
        "agentBoard.notifications.taskCompleted": {
          "type": "boolean",
          "default": true,
          "description": "태스크 완료 시 알림 표시"
        },
        "agentBoard.notifications.taskBlocked": {
          "type": "boolean",
          "default": true,
          "description": "태스크 차단 시 알림 표시"
        }
      }
    },
    "views": {
      "agent-board": [
        {
          "type": "webview",
          "id": "agent-board.boardView",
          "name": "Board",
          "icon": "$(kanban)"
        }
      ]
    }
  },
  "scripts": {
    "prebuild": "node -e \"import('fs').then(f=>{if(!f.existsSync('../webview/dist')){console.error('ERROR: ../webview/dist not found. Build webview first.');process.exit(1);}if(!f.existsSync('../mcp-server/dist/board-server.js')){console.error('ERROR: ../mcp-server/dist/board-server.js not found. Build mcp-server first.');process.exit(1);}f.cpSync('../webview/dist','dist/webview',{recursive:true});f.cpSync('../mcp-server/dist/board-server.js','dist/board-server.js');})\"",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "test": "vitest run",
    "lint": "eslint src/",
    "pretest:e2e": "tsc -p e2e/tsconfig.json",
    "test:e2e": "node e2e/out/runTests.js",
    "prepackage": "node scripts/prepare-vsix.js",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@agent-board/shared": "workspace:*",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@agent-board/mcp-server": "workspace:*",
    "@agent-board/webview": "workspace:*",
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "glob": "^11.0.0",
    "mocha": "^10.0.0"
  }
}
