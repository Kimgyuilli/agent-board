{
  "name": "@agent-board/extension",
  "version": "0.0.1",
  "displayName": "Agent Board",
  "description": "AI 에이전트의 개발 태스크를 관리하고 활동을 실시간 모니터링하는 VS Code 확장",
  "publisher": "agent-board",
  "engines": {
    "vscode": "^1.85.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "categories": ["Other"],
  "contributes": {
    "commands": [
      {
        "command": "agent-board.showBoard",
        "title": "Agent Board: Show Board"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-board",
          "title": "Agent Board",
          "icon": "$(layout-sidebar-left)"
        }
      ]
    },
    "views": {
      "agent-board": [
        {
          "type": "webview",
          "id": "agent-board.boardView",
          "name": "Board",
          "icon": "$(kanban)"
        }
      ]
    }
  },
  "scripts": {
    "prebuild": "node -e \"import('fs').then(f=>f.cpSync('../webview/dist','dist/webview',{recursive:true}))\"",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:better-sqlite3 --format=cjs --platform=node",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@agent-board/shared": "workspace:*",
    "@agent-board/mcp-server": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0"
  }
}
